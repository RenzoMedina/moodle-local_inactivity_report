<div class="container-fluid">
	<div class="d-flex justify-content-end align-items-center mb-3">
		<div class="float-right">
				{{#backurl}}<a href="{{backurl}}" class="btn btn-primary mb-3">{{#str}}back{{/str}}</a>{{/backurl}}
		</div>
	</div>
	<div class="card p-4">
		{{{reportform}}}
	
		<table class="table table-striped mt-4">
			<thead class="text-center">
				<tr>
					<th>{{#str}}fullname{{/str}}</th>
					<th>{{#str}}email{{/str}}</th>
					<th>{{#str}}lastaccess{{/str}}</th>
					<th>{{#str}}dayselapsed, local_inactivity_report{{/str}}</th>
				</tr>
			</thead>
			<tbody class="text-center">
				{{#report}}
				<tr>
					<td>{{fullname}}</td>
					<td>{{email}}</td>
					<td>{{lastaccess}}</td>
					<td>{{dayselapsed}}</td>
				</tr>
				{{/report}}
				{{^report}}
				<tr>
					<td colspan="4" class="text-center">{{#str}}nousersfound, local_inactivity_report{{/str}}</td>
				</tr>
				{{/report}}
			</tbody>
		</table>

	{{#haspagination}}
    <div class="row mt-3">
        <div class="col-12">
            {{{pagination}}}
        </div>
    </div>
    {{/haspagination}}

    <div class="row mt-3">
        <div class="col-12 text-start">
            <a class="btn btn-success" href="{{download_file}}">{{#str}}downloadexcel, local_inactivity_report{{/str}} <i class="fa fa-download"></i></a>
        </div>
    </div>

	</div>
</div>